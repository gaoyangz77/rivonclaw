{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "RIVONCLAW_STAGING",
        "RIVONCLAW_FIRST_PARTY_DOMAIN_ROUTE",
        "RIVONCLAW_CN_RELAY",
        "RIVONCLAW_CONNECTIVITY_PROBE_URL",
        "RIVONCLAW_AFFILIATE_LIVE_TEST_RELATIONSHIP_IDS",
        "DEBUG_AFFILIATE_PROMPT",
        "RIVONCLAW_DEBUG_AFFILIATE_PROMPT",
        "VITE_API_BASE_URL"
      ]
    }
  }
}

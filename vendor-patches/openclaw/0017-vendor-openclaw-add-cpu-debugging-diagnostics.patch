--- /dev/null
+++ b/src/logging/cpu-debugging.ts
@@ -0,0 +1,12 @@
+export function isCpuDebuggingEnabled(env: NodeJS.ProcessEnv = process.env): boolean {
+  const raw = env.CPU_DEBUGGING ?? env.RIVONCLAW_CPU_DEBUGGING;
+  if (!raw) {
+    return false;
+  }
+  const normalized = raw.trim().toLowerCase();
+  return normalized !== "" && normalized !== "0" && normalized !== "false" && normalized !== "off";
+}
+
+export function formatCpuDebugMs(value: number): string {
+  return Math.max(0, Math.round(value)).toString();
+}

diff --git a/src/tasks/task-registry.cpu-debugging.e2e.test.ts b/src/tasks/task-registry.cpu-debugging.e2e.test.ts
new file mode 100644
index 0000000000..8c11bc5967
--- /dev/null
+++ b/src/tasks/task-registry.cpu-debugging.e2e.test.ts
@@ -0,0 +1,78 @@
+import fs from "node:fs/promises";
+import os from "node:os";
+import path from "node:path";
+import { afterEach, beforeEach, describe, expect, it } from "vitest";
+import { resetLogger, setLoggerOverride } from "../logging/logger.js";
+import { createTaskRecord, resetTaskRegistryForTests } from "./task-registry.js";
+import {
+  startCpuDebuggingTaskInspectionSampler,
+  stopCpuDebuggingTaskInspectionSampler,
+} from "./task-registry.maintenance.js";
+
+const originalCpuDebugging = process.env.CPU_DEBUGGING;
+const originalRivonClawCpuDebugging = process.env.RIVONCLAW_CPU_DEBUGGING;
+
+let tempDir: string | undefined;
+let logPath: string | undefined;
+
+describe("task registry CPU debugging e2e", () => {
+  beforeEach(async () => {
+    tempDir = await fs.mkdtemp(path.join(os.tmpdir(), "openclaw-cpu-debug-e2e-"));
+    logPath = path.join(tempDir, "openclaw-cpu-debug.log");
+    process.env.CPU_DEBUGGING = "1";
+    process.env.RIVONCLAW_CPU_DEBUGGING = "1";
+    resetLogger();
+    setLoggerOverride({ level: "warn", consoleLevel: "silent", file: logPath });
+    resetTaskRegistryForTests({ persist: false });
+  });
+
+  afterEach(async () => {
+    stopCpuDebuggingTaskInspectionSampler();
+    resetTaskRegistryForTests({ persist: false });
+    setLoggerOverride(null);
+    resetLogger();
+    if (originalCpuDebugging === undefined) {
+      delete process.env.CPU_DEBUGGING;
+    } else {
+      process.env.CPU_DEBUGGING = originalCpuDebugging;
+    }
+    if (originalRivonClawCpuDebugging === undefined) {
+      delete process.env.RIVONCLAW_CPU_DEBUGGING;
+    } else {
+      process.env.RIVONCLAW_CPU_DEBUGGING = originalRivonClawCpuDebugging;
+    }
+    if (tempDir) {
+      await fs.rm(tempDir, { recursive: true, force: true });
+    }
+    tempDir = undefined;
+    logPath = undefined;
+  });
+
+  it("emits sampled task inspection diagnostics through the real file logger", async () => {
+    const now = Date.now();
+    createTaskRecord({
+      runtime: "cli",
+      ownerKey: "agent:main:main",
+      scopeKind: "session",
+      requesterSessionKey: "agent:main:main",
+      childSessionKey: "agent:main:main",
+      runId: "cpu-debug-e2e-run",
+      task: "Exercise CPU debug task inspection",
+      status: "running",
+      deliveryStatus: "not_applicable",
+      notifyPolicy: "silent",
+      startedAt: now,
+      lastEventAt: now,
+    });
+
+    startCpuDebuggingTaskInspectionSampler({ intervalMs: 10, runImmediately: true });
+
+    const logText = await fs.readFile(logPath!, "utf8");
+    expect(logText).toContain("[cpu-debug] task-registry-inspect");
+    expect(logText).toContain("[cpu-debug] task-inspection-sampler");
+    expect(logText).toContain("taskCount=1");
+    expect(logText).toContain("runningAfter=1");
+    expect(logText).toContain("activeTasks=1");
+    expect(logText).toContain("runId=cpu-debug-e2e-run");
+  });
+});

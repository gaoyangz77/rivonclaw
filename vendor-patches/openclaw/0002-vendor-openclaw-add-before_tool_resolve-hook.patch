From 913c7a283fa98f43da12f5d95df9e148e389d7e4 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Fri, 10 Apr 2026 18:12:32 -0700
Subject: [PATCH] vendor(openclaw): add before_tool_resolve hook for
 per-session tool filtering

Why:
- RivonClaw's capability-manager extension needs to control which tools are
  visible to the LLM on a per-session basis (ADR-031). The existing hook
  points fire too late (after tool resolution), so the system prompt and
  tool list are already built with all tools.

Removal:
- When upstream OpenClaw adds a native per-session tool filtering mechanism
  (e.g. via plugin hook or config), this patch can be dropped.

Tests:
- extensions/rivonclaw-capability-manager/src/__tests__/
---
 src/agents/embedded-agent-runner/compact.ts   | 16 ++++++++++++-
 .../embedded-agent-runner/run/attempt.ts      | 18 +++++++++++++-
 src/plugins/hook-types.ts                     | 15 +++++++++++-
 src/plugins/hooks.ts                          | 24 +++++++++++++++++++
 4 files changed, 70 insertions(+), 3 deletions(-)

diff --git a/src/agents/embedded-agent-runner/compact.ts b/src/agents/embedded-agent-runner/compact.ts
index 0ef6b1d73e..7b0c7a9384 100644
--- a/src/agents/embedded-agent-runner/compact.ts
+++ b/src/agents/embedded-agent-runner/compact.ts
@@ -1002,7 +1002,21 @@ async function compactEmbeddedAgentSessionDirectOnce(
       sessionKey: params.sessionKey,
       sessionId: params.sessionId,
     });
-    const effectiveTools = [...toolSchemaProjection.tools];
+    let effectiveTools = [...toolSchemaProjection.tools];
+    const toolResolveHookRunner = getGlobalHookRunner();
+    if (toolResolveHookRunner?.hasHooks("before_tool_resolve")) {
+      const hookResult = await toolResolveHookRunner.runBeforeToolResolve(
+        { tools: effectiveTools.map((tool) => tool.name) },
+        {
+          agentId: effectiveSkillAgentId,
+          sessionKey: sandboxSessionKey,
+        },
+      );
+      if (hookResult?.tools) {
+        const allowedToolNames = new Set(hookResult.tools);
+        effectiveTools = effectiveTools.filter((tool) => allowedToolNames.has(tool.name));
+      }
+    }
     const allowedToolNames = collectAllowedToolNames({ tools: effectiveTools });
     runtimePlan.tools.logDiagnostics(effectiveTools, runtimePlanModelContext);
     const machineName = await getMachineDisplayName();
diff --git a/src/agents/embedded-agent-runner/run/attempt.ts b/src/agents/embedded-agent-runner/run/attempt.ts
index c818c1225c..1d40276f78 100644
--- a/src/agents/embedded-agent-runner/run/attempt.ts
+++ b/src/agents/embedded-agent-runner/run/attempt.ts
@@ -1652,7 +1652,23 @@ export async function runEmbeddedAttempt(
       sessionKey: params.sessionKey,
       sessionId: params.sessionId,
     });
-    const uncompactedEffectiveTools = [...uncompactedToolSchemaProjection.tools];
+    let uncompactedEffectiveTools = [...uncompactedToolSchemaProjection.tools];
+    const toolResolveHookRunner = getGlobalHookRunner();
+    if (toolResolveHookRunner?.hasHooks("before_tool_resolve")) {
+      const hookResult = await toolResolveHookRunner.runBeforeToolResolve(
+        { tools: uncompactedEffectiveTools.map((tool) => tool.name) },
+        {
+          agentId: sessionAgentId,
+          sessionKey: sandboxSessionKey,
+        },
+      );
+      if (hookResult?.tools) {
+        const allowedToolNames = new Set(hookResult.tools);
+        uncompactedEffectiveTools = uncompactedEffectiveTools.filter((tool) =>
+          allowedToolNames.has(tool.name),
+        );
+      }
+    }
     let effectiveTools = uncompactedEffectiveTools;
     const catalogToolHookContext = {
       agentId: sessionAgentId,
diff --git a/src/plugins/hook-types.ts b/src/plugins/hook-types.ts
index 49e41ae90f..3aa322e34e 100644
--- a/src/plugins/hook-types.ts
+++ b/src/plugins/hook-types.ts
@@ -123,7 +123,8 @@ export type PluginHookName =
   | "reply_dispatch"
   | "before_install"
   | "before_agent_run"
-  | "resolve_exec_env";
+  | "resolve_exec_env"
+  | "before_tool_resolve";
 
 export const PLUGIN_HOOK_NAMES = [
   "before_model_resolve",
@@ -165,6 +166,7 @@ export const PLUGIN_HOOK_NAMES = [
   "before_install",
   "before_agent_run",
   "resolve_exec_env",
+  "before_tool_resolve",
 ] as const satisfies readonly PluginHookName[];
 
 type MissingPluginHookNames = Exclude<PluginHookName, (typeof PLUGIN_HOOK_NAMES)[number]>;
@@ -956,6 +958,13 @@ export type PluginHookGatewayCronService = {
   remove: (id: string) => Promise<PluginHookGatewayCronRemoveResult>;
 };
 
+export type PluginHookBeforeToolResolveEvent = {
+  tools: string[];
+};
+
+export type PluginHookBeforeToolResolveResult = {
+  tools?: string[];
+};
 export type PluginInstallTargetType = "skill" | "plugin";
 export type PluginInstallRequestKind =
   | "skill-install"
@@ -1258,6 +1267,10 @@ export type PluginHookHandlerMap = {
     event: PluginHookResolveExecEnvEvent,
     ctx: PluginHookResolveExecEnvContext,
   ) => Promise<Record<string, string> | void> | Record<string, string> | void;
+  before_tool_resolve: (
+    event: PluginHookBeforeToolResolveEvent,
+    ctx: PluginHookAgentContext,
+  ) => Promise<PluginHookBeforeToolResolveResult | void> | PluginHookBeforeToolResolveResult | void;
 };
 
 export type PluginHookRegistration<K extends PluginHookName = PluginHookName> = {
diff --git a/src/plugins/hooks.ts b/src/plugins/hooks.ts
index 57abb8ce3f..42022f7139 100644
--- a/src/plugins/hooks.ts
+++ b/src/plugins/hooks.ts
@@ -92,6 +92,8 @@ import type {
   PluginHookBeforeInstallResult,
   PluginHookResolveExecEnvContext,
   PluginHookResolveExecEnvEvent,
+  PluginHookBeforeToolResolveEvent,
+  PluginHookBeforeToolResolveResult,
 } from "./hook-types.js";
 
 // Re-export types for consumers
@@ -1252,6 +1254,27 @@ export function createHookRunner(
   // Tool Hooks
   // =========================================================================
 
+  /**
+   * Run before_tool_resolve hook.
+   * Allows plugins to filter the tool list before session creation.
+   * Runs sequentially; last result wins for the tools array.
+   */
+  async function runBeforeToolResolve(
+    event: PluginHookBeforeToolResolveEvent,
+    ctx: PluginHookAgentContext,
+  ): Promise<PluginHookBeforeToolResolveResult | undefined> {
+    return runModifyingHook<"before_tool_resolve", PluginHookBeforeToolResolveResult>(
+      "before_tool_resolve",
+      event,
+      ctx,
+      {
+        mergeResults: (acc, next) => ({
+          tools: next.tools ?? acc?.tools,
+        }),
+      },
+    );
+  }
+
   /**
    * Run before_tool_call hook.
    * Allows plugins to modify or block tool calls.
@@ -1650,6 +1673,7 @@ export function createHookRunner(
     runMessageSending,
     runMessageSent,
     // Tool hooks
+    runBeforeToolResolve,
     runBeforeToolCall,
     runAfterToolCall,
     runToolResultPersist,

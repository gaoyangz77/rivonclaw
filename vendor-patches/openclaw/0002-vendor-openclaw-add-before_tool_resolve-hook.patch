From 758b9c04df4500eed0c6e562627acad5bc438975 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Fri, 10 Apr 2026 18:12:32 -0700
Subject: [PATCH 02/12] vendor(openclaw): add before_tool_resolve hook for
 per-session tool filtering

Why:
- RivonClaw's capability-manager extension needs to control which tools are
  visible to the LLM on a per-session basis (ADR-031). The existing hook
  points fire too late (after tool resolution), so the system prompt and
  tool list are already built with all tools.

Removal:
- When upstream OpenClaw adds a native per-session tool filtering mechanism
  (e.g. via plugin hook or config), this patch can be dropped.

Tests:
- extensions/rivonclaw-capability-manager/src/__tests__/
---
 src/agents/pi-embedded-runner/compact.ts     | 18 ++++++++++++++-
 src/agents/pi-embedded-runner/run/attempt.ts | 15 +++++++++++-
 src/plugins/hook-types.ts                    | 15 +++++++++++-
 src/plugins/hooks.ts                         | 24 ++++++++++++++++++++
 4 files changed, 69 insertions(+), 3 deletions(-)

diff --git a/src/agents/pi-embedded-runner/compact.ts b/src/agents/pi-embedded-runner/compact.ts
index 9917ddc936..1eab961067 100644
--- a/src/agents/pi-embedded-runner/compact.ts
+++ b/src/agents/pi-embedded-runner/compact.ts
@@ -701,10 +701,26 @@ async function compactEmbeddedPiSessionDirectOnce(
       modelApi: model.api,
       model,
     };
-    const tools = runtimePlan.tools.normalize(
+    let tools = runtimePlan.tools.normalize(
       toolsEnabled ? toolsRaw : [],
       runtimePlanModelContext,
     );
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
+        const hookResult = await earlyHookRunner.runBeforeToolResolve(
+          { tools: tools.map((tool) => tool.name) },
+          {
+            agentId: effectiveSkillAgentId,
+            sessionKey: sandboxSessionKey,
+          },
+        );
+        if (hookResult?.tools) {
+          const allowed = new Set(hookResult.tools);
+          tools = tools.filter((tool) => allowed.has(tool.name));
+        }
+      }
+    }
     const bundleMcpRuntime = toolsEnabled
       ? await createBundleMcpToolRuntime({
           workspaceDir: effectiveWorkspace,

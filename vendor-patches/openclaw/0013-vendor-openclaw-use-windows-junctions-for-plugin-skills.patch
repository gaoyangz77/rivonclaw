From 2d928d2d2a0e19076ec03f403a1afdb6563c134a Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sun, 24 May 2026 22:33:11 -0700
Subject: [PATCH] vendor(openclaw): use Windows junctions for plugin skills

Why:
- RivonClaw Windows desktop runs without administrator symlink privileges for many customers.
- OpenClaw plugin skill publication retried a directory symlink on each skills load, producing repeated EPERM warnings for bundled plugin skills such as browser-automation.

Removal:
- Drop when upstream OpenClaw publishes plugin skill directories with Windows junction-compatible links or an equivalent non-symlink fallback.

Tests:
- vendor/openclaw/src/agents/skills/plugin-skills.test.ts
---
 src/agents/skills/plugin-skills.test.ts | 28 ++++++++++++++-
 src/agents/skills/plugin-skills.ts      | 48 +++++++++++++++++++++----
 2 files changed, 69 insertions(+), 7 deletions(-)

diff --git a/src/agents/skills/plugin-skills.test.ts b/src/agents/skills/plugin-skills.test.ts
index d68d4f39bb..d10981537b 100644
--- a/src/agents/skills/plugin-skills.test.ts
+++ b/src/agents/skills/plugin-skills.test.ts
@@ -366,7 +366,7 @@ describe("resolvePluginSkillDirs", () => {
 });
 
 describe("publishPluginSkills", () => {
-  const { publishPluginSkills } = __testing;
+  const { publishPluginSkills, resolvePluginSkillLinkType } = __testing;
 
   async function writeSkillDir(
     parentDir: string,
@@ -399,6 +399,32 @@ describe("publishPluginSkills", () => {
     expect(fsSync.readlinkSync(linkB)).toBe(dirB);
   });
 
+  it("uses Windows junctions for managed plugin skill directory links", () => {
+    expect(resolvePluginSkillLinkType("win32")).toBe("junction");
+    expect(resolvePluginSkillLinkType("darwin")).toBe("dir");
+    expect(resolvePluginSkillLinkType("linux")).toBe("dir");
+  });
+
+  it("deduplicates repeated plugin skill publish failures", async () => {
+    const skillParent = await tempDirs.make("plugin-skills-");
+    const managedDir = await tempDirs.make("managed-skills-");
+    const dir = await writeSkillDir(skillParent, "my-skill");
+    const error = Object.assign(new Error("operation not permitted"), { code: "EPERM" });
+    const symlinkSpy = vi.spyOn(fsSync, "symlinkSync").mockImplementation(() => {
+      throw error;
+    });
+    __testing._resetPluginSkillPublishWarningsForTests();
+
+    try {
+      publishPluginSkills([dir], { pluginSkillsDir: managedDir });
+      publishPluginSkills([dir], { pluginSkillsDir: managedDir });
+    } finally {
+      symlinkSpy.mockRestore();
+    }
+
+    expect(__testing._getPluginSkillPublishWarningCountForTests()).toBe(1);
+  });
+
   it("is idempotent: skips symlinks that already point to the same target", async () => {
     const skillParent = await tempDirs.make("plugin-skills-");
     const managedDir = await tempDirs.make("managed-skills-");
diff --git a/src/agents/skills/plugin-skills.ts b/src/agents/skills/plugin-skills.ts
index 7c2ed971db..b9c1552613 100644
--- a/src/agents/skills/plugin-skills.ts
+++ b/src/agents/skills/plugin-skills.ts
@@ -14,6 +14,7 @@ import { isPathInsideWithRealpath } from "../../security/scan-paths.js";
 import { CONFIG_DIR } from "../../utils.js";
 
 const log = createSubsystemLogger("skills");
+const pluginSkillPublishWarnings = new Set<string>();
 
 export function resolvePluginSkillDirs(params: {
   workspaceDir: string | undefined;
@@ -110,6 +111,29 @@ function resolveDefaultPluginSkillsDir(): string {
   return path.join(CONFIG_DIR, "plugin-skills");
 }
 
+function resolvePluginSkillLinkType(
+  platform = process.platform,
+): NonNullable<Parameters<typeof fs.symlinkSync>[2]> {
+  return platform === "win32" ? "junction" : "dir";
+}
+
+function normalizeLinkTargetForCompare(target: string): string {
+  const withoutNamespace = target.startsWith("\\\\?\\") ? target.slice(4) : target;
+  return path.resolve(withoutNamespace);
+}
+
+function isSameLinkTarget(existingTarget: string, target: string): boolean {
+  return normalizeLinkTargetForCompare(existingTarget) === normalizeLinkTargetForCompare(target);
+}
+
+function warnPluginSkillPublishOnce(key: string, message: string): void {
+  if (pluginSkillPublishWarnings.has(key)) {
+    return;
+  }
+  pluginSkillPublishWarnings.add(key);
+  log.warn(message);
+}
+
 /**
  * Collect skill dir targets from a resolved directory.
  * If the directory contains a direct SKILL.md it is published as-is.
@@ -203,7 +227,7 @@ function publishPluginSkills(skillDirs: string[], opts?: { pluginSkillsDir?: str
     }
     try {
       const existingTarget = fs.readlinkSync(linkPath);
-      if (existingTarget === target) {
+      if (isSameLinkTarget(existingTarget, target)) {
         continue;
       }
       fs.unlinkSync(linkPath);
@@ -214,9 +238,14 @@ function publishPluginSkills(skillDirs: string[], opts?: { pluginSkillsDir?: str
       }
     }
     try {
-      fs.symlinkSync(target, linkPath, "dir");
+      fs.symlinkSync(target, linkPath, resolvePluginSkillLinkType());
     } catch (err) {
-      log.warn(`failed to create plugin skill symlink "${linkPath}" → "${target}": ${String(err)}`);
+      const code = getErrorCode(err);
+      warnPluginSkillPublishOnce(
+        `create:${linkPath}:${target}:${code}`,
+        `failed to publish plugin skill directory "${linkPath}" -> "${target}" ` +
+          `(non-fatal; direct plugin skill loading remains available): ${String(err)}`,
+      );
     }
   }
 
@@ -246,13 +275,20 @@ function publishPluginSkills(skillDirs: string[], opts?: { pluginSkillsDir?: str
 }
 
 function isNotFoundError(err: unknown): boolean {
+  const code = getErrorCode(err);
+  return code === "ENOENT" || code === "ENOTDIR";
+}
+
+function getErrorCode(err: unknown): unknown {
   if (!err || typeof err !== "object") {
-    return false;
+    return undefined;
   }
-  const code = (err as Record<string, unknown>).code;
-  return code === "ENOENT" || code === "ENOTDIR";
+  return (err as Record<string, unknown>).code;
 }
 
 export const __testing = {
   publishPluginSkills,
+  resolvePluginSkillLinkType,
+  _resetPluginSkillPublishWarningsForTests: () => pluginSkillPublishWarnings.clear(),
+  _getPluginSkillPublishWarningCountForTests: () => pluginSkillPublishWarnings.size,
 };
-- 

From 1c17e81bc70802fa9adc29e67a5ea9ad34edf4e4 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sun, 26 Apr 2026 02:44:52 -0700
Subject: [PATCH] vendor(openclaw): brand agent prompt for RivonClaw desktop

Why:
- Patch 0009 removes the CLI quick reference, but the default agent prompt still
  identifies the assistant as running inside OpenClaw and labels user-visible
  runtime/tooling sections as OpenClaw.
- RivonClaw Desktop embeds OpenClaw as the underlying gateway/runtime, but the
  agent-facing product identity should be RivonClaw to avoid mixed-brand answers
  when users ask what prompt/runtime the agent sees.

Removal:
- Drop when upstream OpenClaw supports branded/runtime-specific prompt sections
  or when RivonClaw can post-process default prompt sections without patching
  vendor source.

Tests:
- apps/desktop/src/cs-bridge/vendor-no-openclaw-cli-guidance.sentinel.test.ts
---
 src/agents/system-prompt.ts | 20 ++++++++++----------
 1 file changed, 10 insertions(+), 10 deletions(-)

diff --git a/src/agents/system-prompt.ts b/src/agents/system-prompt.ts
index f32b5e91b4..8b3e684bc7 100644
--- a/src/agents/system-prompt.ts
+++ b/src/agents/system-prompt.ts
@@ -533,7 +533,7 @@ function buildMessagingSection(params: {
     "- Cross-session messaging → use sessions_send(sessionKey, message)",
     subagentOrchestrationGuidance,
     completionEventGuidance,
-    "- Never use exec/curl for provider messaging; OpenClaw handles all routing internally.",
+    "- Never use exec/curl for provider messaging; RivonClaw handles all routing internally.",
     params.availableTools.has("message")
       ? [
           "",
@@ -774,10 +774,10 @@ export function buildAgentSystemPrompt(params: {
     nodes: "List/describe/notify/camera/screen on paired nodes",
     cron: "Manage cron jobs and wake events (use for reminders; when scheduling a reminder, write the systemEvent text as something that will read like a reminder when it fires, and mention that it is a reminder depending on the time gap between setting and firing; include recent context in reminder text if appropriate)",
     message: "Send messages and channel actions",
-    gateway: "Restart, apply config, or run updates on the running OpenClaw process",
+    gateway: "Restart, apply config, or run updates on the running RivonClaw Desktop gateway",
     agents_list: acpSpawnRuntimeEnabled
-      ? 'List OpenClaw agent ids allowed for sessions_spawn when runtime="subagent" (not ACP harness ids)'
-      : "List OpenClaw agent ids allowed for sessions_spawn",
+      ? 'List RivonClaw agent ids allowed for sessions_spawn when runtime="subagent" (not ACP harness ids)'
+      : "List RivonClaw agent ids allowed for sessions_spawn",
     sessions_list: "List other sessions (incl. sub-agents) with filters/last",
     sessions_history: "Fetch history for another session/sub-agent",
     sessions_send: "Send a message to another session/sub-agent",
@@ -994,7 +994,7 @@ export function buildAgentSystemPrompt(params: {
 
   // For "none" mode, return just the basic identity line
   if (promptMode === "none") {
-    return ["You are a personal assistant running inside OpenClaw.", modelIdentityLine]
+    return ["You are a personal assistant running inside RivonClaw Desktop.", modelIdentityLine]
       .filter(Boolean)
       .join("\n");
   }
@@ -1050,7 +1050,7 @@ export function buildAgentSystemPrompt(params: {
   });
   const stablePrefix = cacheStablePromptPrefix(stablePrefixCacheKey, () => {
     const lines = [
-      "You are a personal assistant running inside OpenClaw.",
+      "You are a personal assistant running inside RivonClaw Desktop.",
       "",
       "## Tooling",
       "Available tools are policy-filtered. Names are case-sensitive; call exactly as listed.",
@@ -1139,7 +1139,7 @@ export function buildAgentSystemPrompt(params: {
       }),
       ...safetySection,
       "## RivonClaw Desktop Runtime",
-      "RivonClaw Desktop manages the OpenClaw gateway lifecycle for this session.",
+      "RivonClaw Desktop manages the underlying OpenClaw gateway lifecycle for this session.",
       "Do not run or ask the user to run `openclaw` CLI commands for gateway status, start, stop, or restart.",
       "When available, use first-class runtime tools such as `gateway`, `session_status`, or RivonClaw-provided tools for gateway status, config, and restart instead of shell CLI commands.",
       "If no first-class tool is available, explain the limitation and ask the user before suggesting manual diagnostics.",
@@ -1147,13 +1147,13 @@ export function buildAgentSystemPrompt(params: {
       ...skillsSection,
       ...skillWorkshopSection,
       ...memorySection,
-      hasGateway && !isMinimal ? "## OpenClaw Self-Update" : "",
+      hasGateway && !isMinimal ? "## RivonClaw Desktop Updates" : "",
       hasGateway && !isMinimal
         ? [
             "Only explicit user request.",
             "Before config edits/questions: `config.schema.lookup` for the exact dot path.",
             "Actions: config.get, config.patch, config.apply, update.run. Config writes hot-reload when possible; restart when required.",
-            "After restart, OpenClaw pings the last active session automatically.",
+            "After restart, RivonClaw pings the last active session automatically.",
           ].join("\n")
         : "",
       hasGateway && !isMinimal ? "" : "",
@@ -1247,7 +1247,7 @@ export function buildAgentSystemPrompt(params: {
       }),
       ...bootstrapSystemPromptSections,
       "## Workspace Files (injected)",
-      "These user-editable files are loaded by OpenClaw and included below in Project Context.",
+      "These user-editable files are loaded by RivonClaw and included below in Project Context.",
       "",
       ...buildAssistantOutputDirectivesSection({ isMinimal, sourceMessageToolOnly }),
     ];
-- 

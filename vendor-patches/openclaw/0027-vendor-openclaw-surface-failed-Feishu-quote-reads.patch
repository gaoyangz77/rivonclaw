+export type FeishuMessageFetchFailureReason =
+  | "api_response"
+  | "empty_response"
+  | "parse_error"
+  | "request_exception";
+
+export class FeishuMessageFetchError extends Error {
+  readonly reason: FeishuMessageFetchFailureReason;
+  readonly code?: number;
+  readonly responseMessage?: string;
+  readonly attempts: number;
+
+  constructor(params: {
+    messageId: string;
+    reason: FeishuMessageFetchFailureReason;
+    code?: number;
+    responseMessage?: string;
+    attempts?: number;
+    cause?: unknown;
+  }) {
+    const attempts = params.attempts ?? 1;
+    const details = [
+      `reason=${params.reason}`,
+      `attempts=${attempts}`,
+      params.code === undefined ? undefined : `code=${params.code}`,
+      params.responseMessage ? `responseMessage=${params.responseMessage}` : undefined,
+    ]
+      .filter(Boolean)
+      .join(" ");
+    super(`Feishu message fetch failed for ${params.messageId}: ${details}`, {
+      cause: params.cause,
+    });
+    this.name = "FeishuMessageFetchError";
+    this.reason = params.reason;
+    this.code = params.code;
+    this.responseMessage = params.responseMessage;
+    this.attempts = attempts;
+  }
+}
+
+export function describeFeishuMessageFetchError(error: unknown): string {
+  if (error instanceof FeishuMessageFetchError) {
+    return [
+      `reason=${error.reason}`,
+      `attempts=${error.attempts}`,
+      error.code === undefined ? undefined : `code=${error.code}`,
+      error.responseMessage ? `responseMessage=${error.responseMessage}` : undefined,
+    ]
+      .filter(Boolean)
+      .join(" ");
+  }
+  const reason = error instanceof Error ? error.message : String(error);
+  return `reason=request_exception exception=${reason}`;
+}
+
+function findFeishuRateLimitCode(error: unknown): number | undefined {
+  let current = error;
+  for (let depth = 0; depth < 4 && current; depth += 1) {
+    const code = getFeishuSendRateLimitCode(current);
+    if (code !== undefined) {
+      return code;
+    }
+    current = current instanceof Error ? current.cause : undefined;
+  }
+  return undefined;
+}

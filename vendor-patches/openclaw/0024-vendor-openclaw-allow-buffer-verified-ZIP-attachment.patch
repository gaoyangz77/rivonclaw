From 3ff121f14dd675c06bcfb14da9b051c023aa5955 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sat, 11 Jul 2026 05:46:34 -0700
Subject: [PATCH] vendor(openclaw): allow buffer-verified ZIP attachments

Why:
- Temporary backport: OpenClaw already fixed this regression upstream in openclaw/openclaw@d6881962a3.
- RivonClaw's pinned vendor predates that official fix, so genuine ZIP attachments are rejected before channel upload.
- The upstream fix verifies ZIP payload bytes instead of trusting filename extensions.

Removal:
- Delete this temporary patch after upgrading to an OpenClaw revision containing d6881962a3; it is redundant once the official fix is vendored.

Tests:
- apps/desktop/src/channels/vendor-host-media-zip.sentinel.test.ts
---
 src/media/web-media.test.ts | 15 +++++++++++++++
 src/media/web-media.ts      |  1 +
 2 files changed, 16 insertions(+)

diff --git a/src/media/web-media.test.ts b/src/media/web-media.test.ts
index 8ac6630527..d8588b07c2 100644
--- a/src/media/web-media.test.ts
+++ b/src/media/web-media.test.ts
@@ -303,6 +303,21 @@ describe("loadWebMedia", () => {
     expect(result.contentType).toBe("text/markdown");
   });
 
+  it("allows host-read ZIP files", async () => {
+    const zipFile = path.join(fixtureRoot, "archive.zip");
+    // Write valid ZIP magic bytes (PK\x03\x04) with minimal empty ZIP structure.
+    // file-type detects application/zip from these magic bytes.
+    await fs.writeFile(zipFile, Buffer.from([0x50, 0x4b, 0x03, 0x04]));
+    const result = await loadWebMedia(zipFile, {
+      maxBytes: 1024 * 1024,
+      localRoots: "any",
+      readFile: async (filePath) => await fs.readFile(filePath),
+      hostReadCapability: true,
+    });
+    expect(result.kind).toBe("document");
+    expect(result.contentType).toBe("application/zip");
+  });
+
   it("rejects binary data disguised as a CSV file", async () => {
     const fakeCsv = path.join(fixtureRoot, "evil.csv");
     // Write ZIP magic bytes — file-type detects application/zip (not image, not CSV),
diff --git a/src/media/web-media.ts b/src/media/web-media.ts
index edf37dbad3..5831bff630 100644
--- a/src/media/web-media.ts
+++ b/src/media/web-media.ts
@@ -104,6 +104,7 @@ const HOST_READ_ALLOWED_DOCUMENT_MIMES = new Set([
   "application/vnd.openxmlformats-officedocument.presentationml.presentation",
   "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
   "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
+  "application/zip",
   "text/csv",
   "text/markdown",
 ]);

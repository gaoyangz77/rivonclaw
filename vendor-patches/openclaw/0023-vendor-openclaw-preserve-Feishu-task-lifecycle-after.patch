From e585e2ef46b783ade011c530e89bca0686600ccf Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sat, 11 Jul 2026 01:52:53 -0700
Subject: [PATCH] vendor(openclaw): preserve Feishu task lifecycle after queue
 eviction

Why:
- the five-minute per-chat queue cap resolves the message handler while its agent retry is still running, which closes the Feishu streaming card and detaches the retry

Removal:
- drop when upstream Feishu independently bounds its ordering chain without resolving the original task caller

Tests:
- extensions/feishu/src/sequential-queue.test.ts
- apps/desktop/src/channels/vendor-feishu-queue-lifecycle.sentinel.test.ts
---
 .../feishu/src/sequential-queue.test.ts       | 10 ++++++++-
 extensions/feishu/src/sequential-queue.ts     | 21 +++++++++++--------
 2 files changed, 21 insertions(+), 10 deletions(-)

diff --git a/extensions/feishu/src/sequential-queue.test.ts b/extensions/feishu/src/sequential-queue.test.ts
index a0ea3dfd4d..c6cf0c214b 100644
--- a/extensions/feishu/src/sequential-queue.test.ts
+++ b/extensions/feishu/src/sequential-queue.test.ts
@@ -118,9 +118,17 @@ describe("createSequentialQueue", () => {
     expect(order).toEqual(["stuck:start", "follow-up:ran"]);
     expect(timeouts).toEqual([{ key: "feishu:default:chat-stuck", timeoutMs: 25 }]);
 
-    // Drain the leaked stuck task so it doesn't trip the unhandled-rejection guard.
+    let stuckSettled = false;
+    void stuck.finally(() => {
+      stuckSettled = true;
+    });
+    await Promise.resolve();
+    expect(stuckSettled).toBe(false);
+
+    // The caller still observes the original task lifecycle after queue eviction.
     stuckGate.resolve();
     await stuck;
+    expect(stuckSettled).toBe(true);
   });
 
   it("disables the timeout cap when taskTimeoutMs is 0 (legacy behavior)", async () => {
diff --git a/extensions/feishu/src/sequential-queue.ts b/extensions/feishu/src/sequential-queue.ts
index 04a7a7c19a..f5d44feb33 100644
--- a/extensions/feishu/src/sequential-queue.ts
+++ b/extensions/feishu/src/sequential-queue.ts
@@ -30,8 +30,8 @@ export interface SequentialQueueOptions {
 
   /**
    * Optional callback fired when a task exceeds `taskTimeoutMs`. The task
-   * itself is not awaited further; this callback is the only signal the
-   * caller gets that the queue moved on without it.
+   * remains awaited by its original caller, while the queue moves on without
+   * blocking later same-key tasks behind it.
    */
   onTaskTimeout?: (key: string, timeoutMs: number) => void;
 }
@@ -43,8 +43,11 @@ export function createSequentialQueue(options: SequentialQueueOptions = {}) {
 
   return (key: string, task: () => Promise<void>): Promise<void> => {
     const previous = queues.get(key) ?? Promise.resolve();
-    const wrapped = () => boundedRun(key, task, taskTimeoutMs, onTaskTimeout);
-    const next = previous.then(wrapped, wrapped);
+    const run = previous.then(
+      () => task(),
+      () => task(),
+    );
+    const next = boundedWait(key, run, taskTimeoutMs, onTaskTimeout);
     queues.set(key, next);
     const cleanup = () => {
       if (queues.get(key) === next) {
@@ -52,18 +55,18 @@ export function createSequentialQueue(options: SequentialQueueOptions = {}) {
       }
     };
     next.then(cleanup, cleanup);
-    return next;
+    return run;
   };
 }
 
-async function boundedRun(
+async function boundedWait(
   key: string,
-  task: () => Promise<void>,
+  task: Promise<void>,
   timeoutMs: number,
   onTaskTimeout: ((key: string, timeoutMs: number) => void) | undefined,
 ): Promise<void> {
   if (!Number.isFinite(timeoutMs) || timeoutMs <= 0) {
-    return task();
+    return task;
   }
   let timeoutHandle: ReturnType<typeof setTimeout> | undefined;
   const timeoutPromise = new Promise<void>((resolve) => {
@@ -77,7 +80,7 @@ async function boundedRun(
     }, timeoutMs);
   });
   try {
-    await Promise.race([task(), timeoutPromise]);
+    await Promise.race([task, timeoutPromise]);
   } finally {
     if (timeoutHandle) {
       clearTimeout(timeoutHandle);
-- 

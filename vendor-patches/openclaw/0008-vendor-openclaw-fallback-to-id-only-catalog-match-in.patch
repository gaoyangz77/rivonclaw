From 39f730bf535e09a93d37350ed3d8928eb5e9196d Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Mon, 13 Apr 2026 17:50:09 -0700
Subject: [PATCH] vendor(openclaw): fallback to id-only catalog match in
 resolveGatewayModelSupportsImages

Why:
- Pi SDK ModelRegistry.validateConfig() rejects the entire models.json
  when any provider has models but no apiKey (e.g. codex with auth:token).
  This silently drops ALL custom models from the catalog, including
  correctly configured providers like rivonclaw-pro.
- resolveGatewayModelSupportsImages then fails to find the custom
  provider's entry and returns false, causing images to be dropped.
- The fallback to id-only matching allows the function to find the same
  model under a built-in provider (e.g. openai/gpt-5.4 instead of
  rivonclaw-pro/gpt-5.4) and use its input capabilities.

Removal:
- When Pi SDK fixes validateConfig to accept auth:token as an
  alternative to apiKey, or stops using all-or-nothing rejection
  (upstream issue TBD)

Tests:
- apps/desktop/src/gateway/vendor-image-capability-fallback.sentinel.test.ts
---
 src/gateway/session-utils.ts | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/src/gateway/session-utils.ts b/src/gateway/session-utils.ts
index cd385d6341..358a9c6d5a 100644
--- a/src/gateway/session-utils.ts
+++ b/src/gateway/session-utils.ts
@@ -1000,10 +1000,14 @@ export async function resolveGatewayModelSupportsImages(params: {
 
   try {
     const catalog = await params.loadGatewayModelCatalog();
-    const modelEntry = catalog.find(
-      (entry) =>
-        entry.id === params.model && (!params.provider || entry.provider === params.provider),
-    );
+    const modelEntry =
+      catalog.find(
+        (entry) =>
+          entry.id === params.model && (!params.provider || entry.provider === params.provider),
+      ) ??
+      (params.provider
+        ? catalog.find((entry) => entry.id === params.model)
+        : undefined);
     const normalizedProvider = normalizeOptionalLowercaseString(params.provider);
     const normalizedCandidates = [
       normalizeLowercaseStringOrEmpty(params.model),
-- 

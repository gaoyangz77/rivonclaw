diff --git a/src/media/fetch.ts b/src/media/fetch.ts
index 668d57f41d..dfca575399 100644
--- a/src/media/fetch.ts
+++ b/src/media/fetch.ts
@@ -38,6 +38,10 @@ export type FetchDispatcherAttempt = {
   lookupFn?: LookupFn;
 };
 
+type RivonClawMediaCacheResolveResponse = {
+  url?: unknown;
+};
+
 type FetchMediaOptions = {
   url: string;
   fetchImpl?: FetchLike;
@@ -106,6 +110,84 @@ function redactMediaUrl(url: string): string {
   return redactSensitiveText(url);
 }
 
+function shouldFailHardOnRivonClawMediaCacheError(): boolean {
+  return (
+    process.env.RIVONCLAW_FIRST_PARTY_DOMAIN_ROUTE === "cn-relay" ||
+    process.env.RIVONCLAW_CN_RELAY === "1"
+  );
+}
+
+function isLoopbackUrl(url: string): boolean {
+  try {
+    const parsed = new URL(url);
+    return (
+      parsed.hostname === "localhost" ||
+      parsed.hostname === "127.0.0.1" ||
+      parsed.hostname === "::1" ||
+      parsed.hostname === "[::1]"
+    );
+  } catch {
+    return false;
+  }
+}
+
+async function readResolveErrorSnippet(res: Response): Promise<string> {
+  try {
+    const text = await res.text();
+    return text ? `; body: ${redactSensitiveText(text.slice(0, 512))}` : "";
+  } catch {
+    return "";
+  }
+}
+
+async function resolveRivonClawDesktopMediaCacheUrl(url: string): Promise<string> {
+  if (!/^https?:\/\//i.test(url) || isLoopbackUrl(url)) {
+    return url;
+  }
+
+  const panelPort = process.env.RIVONCLAW_PANEL_PORT?.trim();
+  const desktopToken = process.env.RIVONCLAW_DESKTOP_API_TOKEN?.trim();
+  if (!panelPort || !desktopToken || !/^\d{2,5}$/.test(panelPort)) {
+    return url;
+  }
+
+  const controller = new AbortController();
+  const timeout = setTimeout(() => controller.abort(), 10_000);
+  timeout.unref?.();
+
+  try {
+    const res = await globalThis.fetch(`http://127.0.0.1:${panelPort}/api/media-cache/resolve`, {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
+        "X-RivonClaw-Desktop-Token": desktopToken,
+      },
+      body: JSON.stringify({ sourceUrl: url }),
+      signal: controller.signal,
+    });
+
+    if (!res.ok) {
+      throw new Error(`HTTP ${res.status}${await readResolveErrorSnippet(res)}`);
+    }
+
+    const body = (await res.json()) as RivonClawMediaCacheResolveResponse;
+    if (typeof body.url !== "string" || !/^https?:\/\//i.test(body.url)) {
+      throw new Error("response did not include a valid http(s) url");
+    }
+    return body.url;
+  } catch (err) {
+    if (!shouldFailHardOnRivonClawMediaCacheError()) {
+      return url;
+    }
+    throw new Error(
+      `RivonClaw media cache proxy resolve failed for ${redactMediaUrl(url)}: ${formatErrorMessage(err)}`,
+      { cause: err },
+    );
+  } finally {
+    clearTimeout(timeout);
+  }
+}
+
 export async function fetchRemoteMedia(options: FetchMediaOptions): Promise<FetchMediaResult> {
   const {
     url,
@@ -123,9 +205,10 @@ export async function fetchRemoteMedia(options: FetchMediaOptions): Promise<Fetc

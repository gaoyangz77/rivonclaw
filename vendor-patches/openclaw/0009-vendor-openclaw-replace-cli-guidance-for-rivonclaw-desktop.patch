From 35455ab0fe3775a4c6fbd2164d61fc1b56c33e19 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sat, 25 Apr 2026 20:08:44 -0700
Subject: [PATCH] vendor(openclaw): replace CLI guidance for RivonClaw desktop

Why:
- RivonClaw Desktop does not expose a reliable OpenClaw CLI to agents or end users.
- The upstream system prompt tells agents to run openclaw status and includes an OpenClaw CLI quick reference, which conflicts with RivonClaw's managed gateway runtime and caused us to carry a prompt-prepend extension.

Removal:
- Drop when upstream OpenClaw supports branded/runtime-specific prompt sections or a post-build system-prompt transform that lets RivonClaw remove CLI guidance without patching vendor source.

Tests:
- apps/desktop/src/cs-bridge/vendor-no-openclaw-cli-guidance.sentinel.test.ts
---
 src/agents/system-prompt.ts | 19 ++++++-------------
 1 file changed, 6 insertions(+), 13 deletions(-)

diff --git a/src/agents/system-prompt.ts b/src/agents/system-prompt.ts
index cf09705e3b..a1d80b97b7 100644
--- a/src/agents/system-prompt.ts
+++ b/src/agents/system-prompt.ts
@@ -469,7 +469,7 @@ function buildDocsSection(params: {
     sourcePath
       ? "If docs are incomplete or stale, inspect the local OpenClaw source code before answering."
       : "If docs are incomplete or stale, review the OpenClaw source on GitHub before answering.",
-    "When diagnosing issues, run `openclaw status` yourself when possible; only ask the user if you lack access (e.g., sandboxed).",
+    "When diagnosing issues in RivonClaw Desktop, use available first-class runtime tools instead of shelling out to the OpenClaw CLI.",
     "",
   ];
   return lines.filter((line): line is string => line !== undefined);
@@ -889,18 +889,11 @@ export function buildAgentSystemPrompt(params: {
         fallback: [],
       }),
       ...safetySection,
-      "## OpenClaw CLI Quick Reference",
-      "OpenClaw is controlled via subcommands. Do not invent commands.",
-      "For config changes, use the first-class `gateway` tool (`config.schema.lookup`, `config.get`, `config.patch`, `config.apply`) instead of editing config through exec; the gateway tool hot-reloads config when possible and uses a safe restart only when required.",
-      "Use the `gateway` tool action `restart` for Gateway restarts. Only use CLI service lifecycle commands when the user explicitly asks for them.",
-      "Gateway service lifecycle quick reference:",
-      "- openclaw gateway status",
-      "- openclaw gateway restart",
-      "Operator-only, explicit user request:",
-      "- openclaw gateway start",
-      "- openclaw gateway stop",
-      "Do not chain `openclaw gateway stop` and `openclaw gateway start` as a restart substitute.",
-      "If unsure, ask the user to run `openclaw help` (or `openclaw gateway --help`) and paste the output.",
+      "## RivonClaw Desktop Runtime",
+      "RivonClaw Desktop manages the OpenClaw gateway lifecycle for this session.",
+      "Do not run or ask the user to run `openclaw` CLI commands for gateway status, start, stop, or restart.",
+      "When available, use first-class runtime tools such as `gateway`, `session_status`, or RivonClaw-provided tools for gateway status, config, and restart instead of shell CLI commands.",
+      "If no first-class tool is available, explain the limitation and ask the user before suggesting manual diagnostics.",
       "",
       ...skillsSection,
       ...memorySection,
-- 

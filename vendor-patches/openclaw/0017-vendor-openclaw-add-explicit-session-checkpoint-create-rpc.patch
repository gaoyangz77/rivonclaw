+  "sessions.checkpoint.create": async ({ params, respond, context, client, isWebchatConnect }) => {
+    if (
+      !assertValidParams(
+        params,
+        validateSessionsCheckpointCreateParams,
+        "sessions.checkpoint.create",
+        respond,
+      )
+    ) {
+      return;
+    }
+    const p = params;
+    const key = requireSessionKey(p.key, respond);
+    if (!key) {
+      return;
+    }
+    if (rejectWebchatSessionMutation({ action: "patch", client, isWebchatConnect, respond })) {
+      return;
+    }
+    const checkpointId = normalizeOptionalString(p.checkpointId) ?? "";
+    if (!checkpointId) {
+      respond(false, undefined, errorShape(ErrorCodes.INVALID_REQUEST, "checkpointId required"));
+      return;
+    }
+
+    const loaded = loadSessionEntry(key);
+    const { cfg, entry, canonicalKey, storePath } = loaded;
+    if (!entry?.sessionId) {
+      respond(
+        false,
+        undefined,
+        errorShape(ErrorCodes.INVALID_REQUEST, `session not found: ${key}`),
+      );
+      return;
+    }
+
+    const transcriptFile = resolveSessionTranscriptCandidates(
+      entry.sessionId,
+      storePath,
+      entry.sessionFile,
+      resolveAgentIdFromSessionKey(canonicalKey),
+    ).find((candidate) => {
+      try {
+        return fs.statSync(candidate).isFile();
+      } catch {
+        return false;
+      }
+    });
+
+    if (!transcriptFile) {
+      respond(
+        false,
+        undefined,
+        errorShape(ErrorCodes.INVALID_REQUEST, `session transcript not found: ${canonicalKey}`),
+      );
+      return;
+    }
+
+    const snapshot = await captureCompactionCheckpointSnapshotAsync({
+      sessionFile: transcriptFile,
+      checkpointId,
+    });
+    if (!snapshot) {
+      respond(
+        false,
+        undefined,
+        errorShape(ErrorCodes.UNAVAILABLE, "failed to capture session checkpoint snapshot"),
+      );
+      return;
+    }
+
+    const checkpoint = await persistSessionCompactionCheckpoint({
+      cfg,
+      sessionKey: canonicalKey,
+      sessionId: entry.sessionId,
+      checkpointId,
+      reason: "manual",
+      snapshot,
+      summary: normalizeOptionalString(p.summary),
+      tokensBefore:
+        typeof (entry as { totalTokens?: unknown }).totalTokens === "number"
+          ? (entry as { totalTokens: number }).totalTokens
+          : undefined,
+      postSessionFile: transcriptFile,
+    });
+    if (!checkpoint) {
+      respond(
+        false,
+        undefined,
+        errorShape(ErrorCodes.UNAVAILABLE, "failed to persist session checkpoint"),
+      );
+      return;
+    }
+
+    respond(
+      true,
+      {
+        ok: true,
+        key: canonicalKey,
+        sessionId: entry.sessionId,
+        checkpoint,
+      },
+      undefined,
+    );
+    emitSessionsChanged(context, {
+      sessionKey: canonicalKey,
+      reason: "checkpoint-create",
+    });
+  },

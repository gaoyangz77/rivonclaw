+test("sessions.checkpoint.create persists an explicit checkpoint at the current leaf", async () => {
+  const { dir, storePath } = await createSessionStoreDir();
+  const fixture = await createCheckpointFixture(dir, { legacyPreCompactionSnapshot: false });
+  await writeSessionStore({
+    entries: {
+      main: sessionStoreEntry(fixture.sessionId, {
+        sessionFile: fixture.sessionFile,
+        totalTokens: 321,
+      }),
+    },
+  });
+  const { ws } = await openClient();
+
+  const created = await rpcReq<{
+    ok: true;
+    key: string;
+    sessionId: string;
+    checkpoint: { checkpointId: string; summary?: string; tokensBefore?: number };
+  }>(ws, "sessions.checkpoint.create", {
+    key: "main",
+    checkpointId: "manual-before-dispatch",
+    summary: "before customer-service dispatch",
+  });
+
+  expect(created.ok).toBe(true);
+  expect(created.payload).toMatchObject({
+    key: "agent:main:main",
+    sessionId: fixture.sessionId,
+    checkpoint: {
+      checkpointId: "manual-before-dispatch",
+      summary: "before customer-service dispatch",
+      tokensBefore: 321,
+    },
+  });
+  const store = JSON.parse(await fs.readFile(storePath, "utf8")) as Record<
+    string,
+    { compactionCheckpoints?: Array<{ checkpointId?: string }> }
+  >;
+  expect(store["agent:main:main"]?.compactionCheckpoints).toEqual([
+    expect.objectContaining({ checkpointId: "manual-before-dispatch" }),
+  ]);
+  ws.close();
+});
+

From f0adb3f9ce1f21375debd7301c92344f8fdb88d9 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Fri, 10 Jul 2026 04:59:37 -0700
Subject: [PATCH] vendor(openclaw): handle taskkill spawn errors

Why:
- Windows packaged runtimes can omit taskkill from PATH, causing an asynchronous ENOENT event that crashes the gateway while an exec child is being terminated.
- Backport upstream openclaw/openclaw#101392 (55fa22b) so process cleanup remains best-effort.

Upstream:
- Already fixed by openclaw/openclaw#101392 in commit 55fa22b482a7c6b8163f47590047c34b0dcd7382.
- Deprecate and remove this patch as soon as the pinned OpenClaw version contains that commit.

Removal:
- Drop after the pinned OpenClaw version includes upstream commit 55fa22b482a7c6b8163f47590047c34b0dcd7382.

Tests:
- apps/desktop/src/gateway/vendor-taskkill-spawn-error.sentinel.test.ts
- vendor/openclaw/src/process/kill-tree.test.ts
---
 packages/agent-core/src/harness/env/kill-tree.ts |  3 ++-
 src/process/kill-tree.test.ts                    | 13 +++++++++++++
 2 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/packages/agent-core/src/harness/env/kill-tree.ts b/packages/agent-core/src/harness/env/kill-tree.ts
index 4ea5f2e5de..236e4c1a64 100644
--- a/packages/agent-core/src/harness/env/kill-tree.ts
+++ b/packages/agent-core/src/harness/env/kill-tree.ts
@@ -110,11 +110,12 @@ function signalProcessTreeUnix(
 
 function runTaskkill(args: string[]): void {
   try {
-    spawn("taskkill", args, {
+    const child = spawn("taskkill", args, {
       stdio: "ignore",
       detached: true,
       windowsHide: true,
     });
+    child.once("error", () => {});
   } catch {
     // Ignore taskkill spawn failures.
   }
diff --git a/src/process/kill-tree.test.ts b/src/process/kill-tree.test.ts
index 57fbe6709d..5f00282bef 100644
--- a/src/process/kill-tree.test.ts
+++ b/src/process/kill-tree.test.ts
@@ -1,4 +1,5 @@
 // Kill tree tests cover process tree termination and platform-specific fallbacks.
+import { EventEmitter } from "node:events";
 import { afterEach, beforeAll, beforeEach, describe, expect, it, vi } from "vitest";
 import { withMockedPlatform } from "../test-utils/vitest-spies.js";
 
@@ -40,6 +41,7 @@ describe("killProcessTree", () => {
 
   beforeEach(() => {
     spawnMock.mockClear();
+    spawnMock.mockReturnValue({ once: vi.fn() });
     killSpy = vi.spyOn(process, "kill");
     vi.useFakeTimers();
   });
@@ -88,6 +90,17 @@ describe("killProcessTree", () => {
     });
   });
 
+  it("on Windows ignores asynchronous taskkill spawn errors", async () => {
+    const taskkillChild = new EventEmitter();
+    spawnMock.mockReturnValueOnce(taskkillChild);
+
+    await withMockedPlatform("win32", async () => {
+      killProcessTree(9191, { graceMs: 25 });
+      expect(() => taskkillChild.emit("error", new Error("spawn ENOENT"))).not.toThrow();
+      expectTaskkillCall(0, ["/T", "/PID", "9191"]);
+    });
+  });
+
   it("on Unix sends SIGTERM first and skips SIGKILL when process exits", async () => {
     killSpy.mockImplementation(((pid: number, signal?: NodeJS.Signals | number) => {
       if (pid === -3333 && signal === 0) {

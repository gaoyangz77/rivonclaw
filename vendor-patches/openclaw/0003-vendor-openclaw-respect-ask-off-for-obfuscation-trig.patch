From 598d3fb1e91dd341eaed40ccd03d99644c59e446 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Sun, 29 Mar 2026 00:32:35 -0700
Subject: [PATCH] vendor(openclaw): respect ask=off for obfuscation-triggered
 approvals

Why:
- EasyClaw sets exec.ask=off and exec.security=full for the local Chat Page
- OpenClaw's obfuscation detection unconditionally forces approval even when
  ask=off, causing approval timeouts with no UI to resolve them
- The Chat Page runs on localhost; physical access implies full trust, so
  obfuscation gating adds no security value in this context

Removal:
- Drop when upstream OpenClaw makes obfuscation detection respect the ask
  setting natively (file issue or PR upstream)

Tests:
- packages/gateway/src/exec-obfuscation-ask-off.test.ts
---
 src/agents/bash-tools.exec-host-gateway.ts | 2 +-
 src/agents/bash-tools.exec-host-node.ts    | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/agents/bash-tools.exec-host-gateway.ts b/src/agents/bash-tools.exec-host-gateway.ts
index 149a4785dd..eed3314a8a 100644
--- a/src/agents/bash-tools.exec-host-gateway.ts
+++ b/src/agents/bash-tools.exec-host-gateway.ts
@@ -133,7 +133,7 @@ export async function processGatewayAllowlist(
       allowlistSatisfied,
     }) ||
     requiresHeredocApproval ||
-    obfuscation.detected;
+    (obfuscation.detected && hostAsk !== "off");
   if (requiresHeredocApproval) {
     params.warnings.push(
       "Warning: heredoc execution requires explicit approval in allowlist mode.",
diff --git a/src/agents/bash-tools.exec-host-node.ts b/src/agents/bash-tools.exec-host-node.ts
index 16af23590b..23ac55dfa8 100644
--- a/src/agents/bash-tools.exec-host-node.ts
+++ b/src/agents/bash-tools.exec-host-node.ts
@@ -176,7 +176,7 @@ export async function executeNodeHostCommand(
       security: hostSecurity,
       analysisOk,
       allowlistSatisfied,
-    }) || obfuscation.detected;
+    }) || (obfuscation.detected && hostAsk !== "off");
   const invokeTimeoutMs = Math.max(
     10_000,
     (typeof params.timeoutSec === "number" ? params.timeoutSec : params.defaultTimeoutSec) * 1000 +
-- 
2.50.1 (Apple Git-155)


+type ImagePromptWorkerResponse =
+  | { type: "success"; result: ImagePromptResult }
+  | { type: "error"; error: string };
+
+function shouldUseImagePromptChildProcess(): boolean {
+  if (process.env.OPENCLAW_IMAGE_TOOL_CHILD_PROCESS === "0") {
+    return false;
+  }
+  if (process.env.OPENCLAW_IMAGE_TOOL_CHILD_PROCESS === "1") {
+    return true;
+  }
+  return process.env.VITEST !== "true";
+}
+
+function resolveImagePromptWorkerPath(): string {
+  const here = dirname(fileURLToPath(import.meta.url));
+  const candidates = [
+    resolve(here, "agents/tools/image-tool-worker.js"),
+    resolve(here, "image-tool-worker.js"),
+    resolve(process.cwd(), "dist/agents/tools/image-tool-worker.js"),
+  ];
+  const found = candidates.find((candidate) => existsSync(candidate));
+  if (!found) {
+    throw new Error(`image tool worker entry not found; checked ${candidates.join(", ")}`);
+  }
+  return found;
+}
+
+async function runImagePromptInChildProcess(params: ImagePromptParams): Promise<ImagePromptResult> {
+  const child = fork(resolveImagePromptWorkerPath(), [], {
+    env: {
+      ...process.env,
+      ...(process.versions.electron ? { ELECTRON_RUN_AS_NODE: "1" } : {}),
+    },
+    execArgv: [],
+    serialization: "advanced",
+    stdio: ["ignore", "ignore", "pipe", "ipc"],
+  });
+  return await new Promise<ImagePromptResult>((resolvePromise, rejectPromise) => {
+    let settled = false;
+    const configuredTimeout = Number(process.env.OPENCLAW_IMAGE_TOOL_CHILD_TIMEOUT_MS);
+    const timeoutMs =
+      Number.isFinite(configuredTimeout) && configuredTimeout > 0
+        ? configuredTimeout
+        : DEFAULT_CHILD_PROCESS_TIMEOUT_MS;
+    const timeout = setTimeout(
+      () => finish(new Error(`image tool worker timed out after ${timeoutMs}ms`), true),
+      timeoutMs,
+    );
+    const finish = (error?: Error, kill = false, result?: ImagePromptResult) => {
+      if (settled) {
+        return;
+      }
+      settled = true;
+      clearTimeout(timeout);
+      if (kill && !child.killed) {
+        child.kill("SIGKILL");
+      }
+      if (error) {
+        rejectPromise(error);
+      } else if (result) {
+        resolvePromise(result);
+      } else {
+        rejectPromise(new Error("image tool worker returned no result"));
+      }
+    };
+    child.on("message", (message: unknown) => {
+      const response = message as ImagePromptWorkerResponse | undefined;
+      if (response?.type === "success") {
+        finish(undefined, false, response.result);
+      } else if (response?.type === "error") {
+        finish(new Error(response.error || "image tool worker failed"));
+      } else {
+        finish(new Error("image tool worker returned an invalid response"));
+      }
+    });
+    child.once("error", (error) => finish(error));
+    child.once("exit", (code, signal) => {
+      if (!settled) {
+        finish(
+          new Error(
+            `image tool worker exited before response: code=${code ?? "null"} signal=${signal ?? "null"}`,
+          ),
+        );
+      }
+    });
+    child.send({
+      type: "run-image-prompt",
+      params: { ...params, authStore: undefined },
+    });
+  });
+}
+
+let imagePromptChildRunner = runImagePromptInChildProcess;
+
+async function runImagePromptWithWorkerFallback(
+  params: ImagePromptParams,
+): Promise<ImagePromptResult> {
+  if (!shouldUseImagePromptChildProcess()) {
+    return await runImagePrompt(params);
+  }
+  try {
+    return await imagePromptChildRunner(params);
+  } catch (err) {
+    log.warn(`image tool worker unavailable; using main process: ${formatErrorMessage(err)}`);
+    return await runImagePrompt(params);
+  }
+}
+
 export function createImageTool(options?: {
   config?: OpenClawConfig;
   agentDir?: string;

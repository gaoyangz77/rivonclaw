+type ImagePromptWorkerRequest = {
+  type: "run-image-prompt";
+  params: ImagePromptParams;
+};
+
+type ImagePromptWorkerResponse =
+  | { type: "success"; result: ImagePromptResult }
+  | { type: "error"; error: string };
+
+function shouldUseImagePromptChildProcess(): boolean {
+  if (process.env.OPENCLAW_IMAGE_TOOL_CHILD_PROCESS === "0") {
+    return false;
+  }
+  if (process.env.OPENCLAW_IMAGE_TOOL_CHILD_PROCESS === "1") {
+    return true;
+  }
+  return process.env.VITEST !== "true";
+}
+
+function resolveImagePromptWorkerPath(): string {
+  const here = dirname(fileURLToPath(import.meta.url));
+  const candidates = [
+    resolve(here, "agents/tools/image-tool-worker.js"),
+    resolve(here, "image-tool-worker.js"),
+    resolve(process.cwd(), "dist/agents/tools/image-tool-worker.js"),
+  ];
+  const found = candidates.find((candidate) => existsSync(candidate));
+  if (!found) {
+    throw new Error(`image tool worker entry not found; checked ${candidates.join(", ")}`);
+  }
+  return found;
+}
+
+async function runImagePromptInChildProcess(params: ImagePromptParams): Promise<ImagePromptResult> {
+  const workerPath = resolveImagePromptWorkerPath();
+  const startedAt = Date.now();
+  const child = fork(workerPath, [], {
+    env: {
+      ...process.env,
+      ...(process.versions.electron ? { ELECTRON_RUN_AS_NODE: "1" } : {}),
+    },
+    execArgv: [],
+    serialization: "advanced",
+    stdio: ["ignore", "ignore", "pipe", "ipc"],
+  });
+  const childPid = child.pid ?? "unknown";
+  log.info(`image tool worker start: pid=${childPid} images=${params.images.length}`);
+
+  return await new Promise<ImagePromptResult>((resolvePromise, rejectPromise) => {
+    let settled = false;
+    const timeoutMs = (() => {
+      const raw = Number(process.env.OPENCLAW_IMAGE_TOOL_CHILD_TIMEOUT_MS);
+      return Number.isFinite(raw) && raw > 0 ? raw : DEFAULT_CHILD_PROCESS_TIMEOUT_MS;
+    })();
+    const timeout = setTimeout(() => {
+      finish(
+        new Error(`image tool worker timed out after ${timeoutMs}ms`),
+        undefined,
+        true,
+      );
+    }, timeoutMs);
+
+    function cleanup() {
+      clearTimeout(timeout);
+      child.off("message", onMessage);
+      child.off("error", onError);
+      child.off("exit", onExit);
+      child.stderr?.off("data", onStderr);
+    }
+
+    function finish(error?: Error, result?: ImagePromptResult, kill = false) {
+      if (settled) return;
+      settled = true;
+      cleanup();
+      if (kill && !child.killed) {
+        child.kill("SIGKILL");
+      }
+      const durationMs = Date.now() - startedAt;
+      if (error) {
+        log.warn(
+          `image tool worker failed: pid=${childPid} durationMs=${durationMs} error=${formatErrorMessage(error)}`,
+        );
+        rejectPromise(error);
+        return;
+      }
+      log.info(`image tool worker success: pid=${childPid} durationMs=${durationMs}`);
+      resolvePromise(result!);
+    }
+
+    function onMessage(message: unknown) {
+      const response = message as ImagePromptWorkerResponse | undefined;
+      if (response?.type === "success") {
+        finish(undefined, response.result);
+        return;
+      }
+      if (response?.type === "error") {
+        finish(new Error(response.error || "image tool worker failed"));
+        return;
+      }
+      finish(new Error("image tool worker returned an invalid response"));
+    }
+
+    function onError(error: Error) {
+      finish(error);
+    }
+
+    function onExit(code: number | null, signal: NodeJS.Signals | null) {
+      if (!settled) {
+        finish(
+          new Error(
+            `image tool worker exited before response: code=${code ?? "null"} signal=${signal ?? "null"}`,
+          ),
+        );
+      }
+    }
+
+    function onStderr(data: Buffer) {
+      const text = data.toString("utf8").trim();
+      if (text) {
+        log.warn(`image tool worker stderr: pid=${childPid} ${text}`);
+      }
+    }
+
+    child.on("message", onMessage);
+    child.on("error", onError);
+    child.on("exit", onExit);
+    child.stderr?.on("data", onStderr);
+    child.send({ type: "run-image-prompt", params } satisfies ImagePromptWorkerRequest);
+  });
+}
+
+let imagePromptChildRunner = runImagePromptInChildProcess;
+
+async function runImagePromptWithWorkerFallback(
+  params: ImagePromptParams,
+): Promise<ImagePromptResult> {
+  if (!shouldUseImagePromptChildProcess()) {
+    return await runImagePrompt(params);
+  }
+  try {
+    return await imagePromptChildRunner(params);
+  } catch (err) {
+    log.warn(
+      `image tool worker unavailable; falling back to main process: ${formatErrorMessage(err)}`,
+    );
+    return await runImagePrompt(params);
+  }
+}
+
 export function createImageTool(options?: {
   config?: OpenClawConfig;
   agentDir?: string;

index 0000000000..f1e6a754b5
--- /dev/null
+++ b/src/agents/tools/image-tool-worker.ts
@@ -0,0 +1,38 @@
+import { formatErrorMessage } from "../../infra/errors.js";
+import {
+  runImagePrompt,
+  type ImagePromptParams,
+  type ImagePromptResult,
+} from "./image-tool.js";
+
+type ImagePromptWorkerRequest = {
+  type: "run-image-prompt";
+  params: ImagePromptParams;
+};
+
+type ImagePromptWorkerResponse =
+  | { type: "success"; result: ImagePromptResult }
+  | { type: "error"; error: string };
+
+function send(response: ImagePromptWorkerResponse): void {
+  if (typeof process.send === "function") {
+    process.send(response);
+  }
+}
+
+process.on("message", async (message: unknown) => {
+  const request = message as ImagePromptWorkerRequest | undefined;
+  if (request?.type !== "run-image-prompt") {
+    send({ type: "error", error: "invalid image tool worker request" });
+    return;
+  }
+
+  try {
+    const result = await runImagePrompt(request.params);
+    send({ type: "success", result });
+  } catch (err) {
+    send({ type: "error", error: formatErrorMessage(err) });
+  } finally {
+    process.exit(0);
+  }
+});

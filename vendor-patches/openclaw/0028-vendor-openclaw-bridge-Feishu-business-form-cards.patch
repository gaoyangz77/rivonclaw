+++ b/extensions/feishu/src/monitor.card-action-form.test.ts
@@ -0,0 +1,94 @@
+import { describe, expect, it } from "vitest";
+import { parseFeishuCardActionEventPayload } from "./monitor.account.js";
+
+describe("Feishu form card callback parsing", () => {
+  it("preserves form callback fields and message context", () => {
+    const parsed = parseFeishuCardActionEventPayload({
+      token: "callback-token",
+      operator: { open_id: "ou_operator", user_id: "user_operator" },
+      action: {
+        tag: "form_submit",
+        name: "submit-response",
+        form_name: "cs_escalation",
+        value: { action: "rivonclaw.cs:respond", escalationId: "M1DG8V" },
+        form_value: { decision: "Refund", resolution: "resolved" },
+      },
+      context: { chat_id: "oc_chat", open_message_id: "om_card" },
+    });
+
+    expect(parsed).toEqual(
+      expect.objectContaining({
+        token: "callback-token",
+        operator: expect.objectContaining({ open_id: "ou_operator", user_id: "user_operator" }),
+        action: {
+          tag: "form_submit",
+          name: "submit-response",
+          form_name: "cs_escalation",
+          value: { action: "rivonclaw.cs:respond", escalationId: "M1DG8V" },
+          form_value: { decision: "Refund", resolution: "resolved" },
+        },
+        open_message_id: "om_card",
+        context: expect.objectContaining({ chat_id: "oc_chat", open_message_id: "om_card" }),
+      }),
+    );
+  });
+
+  it("accepts Schema 2 callbacks that use the flattened header event_id", () => {
+    const parsed = parseFeishuCardActionEventPayload({
+      schema: "2.0",
+      event_id: "schema-2-event-id",
+      operator: { open_id: "ou_operator" },
+      action: {
+        tag: "form_submit",
+        value: { action: "rivonclaw.cs:respond", escalationId: "0B67JE" },
+        form_value: { decision: "Safe test response", resolution: "resolved" },
+      },
+      context: { open_chat_id: "oc_chat", open_message_id: "om_card" },
+    });
+
+    expect(parsed).toEqual(
+      expect.objectContaining({
+        token: "schema-2-event-id",
+        operator: expect.objectContaining({ open_id: "ou_operator" }),
+        action: expect.objectContaining({
+          tag: "form_submit",
+          form_value: { decision: "Safe test response", resolution: "resolved" },
+        }),
+        context: expect.objectContaining({ chat_id: "oc_chat", open_message_id: "om_card" }),
+      }),
+    );
+  });
+
+  it("recovers a namespaced business action from form_submit name when value is omitted", () => {
+    const parsed = parseFeishuCardActionEventPayload({
+      schema: "2.0",
+      event_id: "schema-2-form-event",
+      token: "schema-2-token",
+      operator: { open_id: "ou_operator" },
+      action: {
+        tag: "form_submit",
+        name: "rivonclaw.cs:respond:0B67JE",
+        form_value: { decision: "Safe test response", resolution: "resolved" },
+      },
+      context: { open_chat_id: "oc_chat", open_message_id: "om_card" },
+    });
+
+    expect(parsed?.action).toEqual({
+      tag: "form_submit",
+      name: "rivonclaw.cs:respond:0B67JE",
+      value: { action: "rivonclaw.cs:respond:0B67JE" },
+      form_value: { decision: "Safe test response", resolution: "resolved" },
+    });
+  });
+
+  it("does not invent a business action for ordinary form names", () => {
+    expect(
+      parseFeishuCardActionEventPayload({
+        token: "callback-token",
+        operator: { open_id: "ou_operator" },
+        action: { tag: "form_submit", name: "submit", form_value: { answer: "yes" } },
+        context: { open_chat_id: "oc_chat", open_message_id: "om_card" },
+      }),
+    ).toBeNull();
+  });
+});
